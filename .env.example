# ============================================
# QuickBooks Online MCP Server - Configuration
# ============================================


# 🏢🏢🏢 MULTI-TENANT CONFIGURATION
# ----------------------------------------------------
# This mode allows multiple users to connect simultaneously.
# The server will ignore hardcoded API keys below and dynamically
# authenticate using tokens provided in each incoming request.

ENFORCE_AUTH=false
PLATFORM_INT_URL=


# 🏢 SINGLE-TENANT (LOCAL) CONFIGURATION
# ----------------------------------------------------
# This mode is used when ENFORCE_AUTH is false or missing.
# It hardcodes the server to one specific QuickBooks company using these credentials.

QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENVIRONMENT=sandbox

# ⚠️  IMPORTANT: Replace the value below with a REAL refresh token from the
#     Intuit OAuth Playground: https://developer.intuit.com/app/developer/playground
QUICKBOOKS_REFRESH_TOKEN=sandbox_test_token_123


# 🌐 HTTP SERVER SETTINGS
# ----------------------------------------------------
# Set PORT to enable HTTP mode instead of stdio
#PORT=3000
MCP_HTTP_PATH=/mcp


# 📊 OPTIONAL: USAGE TRACKING
# ----------------------------------------------------
# USAGE_REPORT_ENDPOINT=


# 🔐 OPTIONAL: LICENSE SERVER
# ----------------------------------------------------
# LICENSE_SERVER_BASE_URL=
# LICENSE_SERVER_JWKS_ENDPOINT=/.well-known/jwks.json
# LICENSE_SERVER_ACTIVATION_ENDPOINT=/activate
# LICENSE_KEY=
